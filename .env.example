# .env.example — Vorlage für Secrets und Konfiguration (diese Datei ist im Git)
# Kopieren nach .env und Werte eintragen:
#   cp .env.example .env
#
# .env ist in .gitignore und wird NICHT committed.

# --- Gitea ---
GITEA_URL=http://your-gitea-host:3000
GITEA_USER=your-username
GITEA_TOKEN=
# Token erstellen: Gitea → Settings → Applications → Generate Token
# Benötigte Scopes: issue (read+write), repository (read+write)

# --- Repository ---
GITEA_REPO=your-username/your-repo
# Format: owner/repo-name (wie in der URL)

# --- Bot-User (optional, empfohlen) ---
GITEA_BOT_USER=working-bot
GITEA_BOT_TOKEN=
# Separater Gitea-User für Kommentare — macht Agent-Nachrichten erkennbar
# Nur API-Token nötig, kein SSH/GPG-Key

# --- Projekt ---
PROJECT_ROOT=/path/to/your/project
# Absoluter Pfad zum Projekt-Repo das bearbeitet wird
# Standard: Elternverzeichnis von agent_start.py

# --- Workflow Labels (Standard-Werte müssen in Gitea existieren) ---
LABEL_READY=ready-for-agent
LABEL_PROPOSED=agent-proposed
LABEL_PROGRESS=in-progress
LABEL_REVIEW=needs-review

# --- Risiko-Klassifikation ---
RISK_BUG_LABELS=bug
RISK_FEAT_LABELS=Feature request
RISK_ENAK_LABELS=enhancement
# Schlüsselwörter im Titel die Enhancement als Stufe 1 einstufen
SAFE_KEYWORDS=docstring,docs,comment,dead code,cleanup,import

# --- Branch-Generierung ---
PREFIX_FIX=fix
PREFIX_FEAT=feat
PREFIX_DOCS=docs
PREFIX_DEFAULT=chore
# Schlüsselwörter im Titel die docs-Präfix auslösen
DOCS_KEYWORDS=docs,docstring,comment

# --- Datei-Analyse ---
CODE_EXTENSIONS=.py,.js,.sh,.yaml,.md
MAX_FILE_LINES=300

# --- Gitea API ---
ISSUE_LIMIT=50
PR_BASE_BRANCH=main
# Kommentare die als Freigabe gewertet werden (kommagetrennt, case-insensitive)
APPROVAL_KEYWORDS=ok,yes,ja,approved,freigabe,👍,✅
# Text im Agent-Kommentar der den letzten Agent-Kommentar markiert
AGENT_MARKER=OK zum Implementieren?

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=gitea-agent.log

# Claude Code Auto-Approve — schreibt .claude/settings.local.json beim Start
# true  → alle Tool-Calls automatisch erlaubt (kein manuelles Bestätigen)
# false → Claude Code fragt bei jedem Tool nach (Standard)
AUTO_APPROVE=false

# --- Pfade ---
# CONTEXT_DIR=contexts
# Relativ zu agent_start.py oder absolut, z.B.:
#   contexts                              → <script-dir>/contexts/
#   /home/user/myproject/contexts         → absoluter Pfad
#   ../contexts                           → Elternverzeichnis

# --- Textbausteine (optional — Standardwerte in settings.py) ---
# PROJECT_ROOT=/path/to/project
# APPROVAL_PROMPT=Antworte mit ok, ja oder ✅ um die Implementierung zu starten.
# PR_CHECKLIST=Code geändert,Dokumentation aktualisiert,Kein toter Code hinzugefügt,Getestet
# COMPLETION_NEXT_STEP=PR reviewen und mergen.\nNach dem Merge: Issue schließen.
# Hinweis: PLAN_PLACEHOLDER_TEXT ist mehrzeilig — direkt in settings.py editieren

# --- Claude API (optional) ---
CLAUDE_API_ENABLED=false
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
HEALING_MAX_ATTEMPTS=3
HEALING_MAX_TOKENS=50000

SERVER_URL=http://localhost:8000
SERVER_WAIT_TIMEOUT=300
SERVER_WAIT_INTERVAL=10
SESSION_LIMIT=2
SESSION_RESET_HOURS=4
SLICE_GATE_ENABLED=false
SLICE_GATE_MIN_LINES=100
LABEL_HELP=help wanted
