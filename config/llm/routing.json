{
    "_comment": "Vorlage für llm_routing.json — nach agent/config/llm_routing.json kopieren und anpassen",
    "_comment_providers": "Unterstützte Provider: claude, openai, gemini, deepseek, lmstudio, local (Ollama-Format)",
    "_comment_fallback": "Ohne diese Datei → DEEPSEEK_API_ENABLED / CLAUDE_API_ENABLED / LLM_LOCAL_URL aus .env",
    "_comment_system_prompt": "system_prompt: relativer Pfad zu einer .md-Datei im Projekt-Root (z.B. config/llm/prompts/senior_python.md)",
    "_comment_cli_cmd": "cli_cmd (optional): CLI-Binary für interaktive Console-Sessions via context_export.sh --llm",

    "default": {
        "provider": "claude",
        "model": "claude-sonnet-4-6",
        "max_tokens": 1024,
        "timeout": 60
    },

    "tasks": {
        "_comment": "Jeder Task-Typ ist optional — fehlende Einträge verwenden 'default'",

        "issue_analysis": {
            "provider": "claude",
            "model": "claude-haiku-4-5-20251001",
            "system_prompt": "config/llm/prompts/analyst.md",
            "_comment": "Günstig + schnell für Issue-Analyse"
        },
        "implementation": {
            "provider": "claude",
            "model": "claude-sonnet-4-6",
            "system_prompt": "config/llm/prompts/senior_python.md",
            "cli_cmd": "claude",
            "_comment": "Stark für Code-Implementierung — cli_cmd für interaktive Sessions"
        },
        "pr_review": {
            "provider": "claude",
            "model": "claude-sonnet-4-6",
            "system_prompt": "config/llm/prompts/reviewer.md",
            "_comment": "Analytisch für PR-Reviews"
        },
        "test_generation": {
            "provider": "local",
            "model": "llama3",
            "base_url": "http://localhost:11434",
            "system_prompt": "config/llm/prompts/senior_python.md",
            "_comment": "Lokal für deterministischen Test-Code"
        },
        "log_analysis": {
            "provider": "claude",
            "model": "claude-haiku-4-5-20251001",
            "system_prompt": "config/llm/prompts/log_analyst.md",
            "_comment": "Günstig für Log-Mustererkennung"
        },
        "healing": {
            "provider": "claude",
            "model": "claude-sonnet-4-6",
            "system_prompt": "config/llm/prompts/healer.md",
            "_comment": "Präzise für Self-Healing Entscheidungen"
        },
        "docs": {
            "provider": "claude",
            "model": "claude-haiku-4-5-20251001",
            "system_prompt": "config/llm/prompts/docs_writer.md",
            "cli_cmd": "claude",
            "_comment": "Günstig + schnell für Dokumentation, Docstrings, Kommentare"
        },
        "deep_coding": {
            "provider": "claude",
            "model": "claude-sonnet-4-6",
            "system_prompt": "config/llm/prompts/senior_python.md",
            "cli_cmd": "claude",
            "_comment": "Komplexe Implementierungen, Refactorings, Architektur-Entscheidungen"
        }
    },

    "_examples": {
        "openai_provider": {
            "provider": "openai",
            "model": "gpt-4o-mini",
            "base_url": "https://api.openai.com/v1",
            "_env": "OPENAI_API_KEY=sk-..."
        },
        "gemini_provider": {
            "provider": "gemini",
            "model": "gemini-1.5-flash",
            "_env": "GEMINI_API_KEY=AIza..."
        },
        "groq_via_openai": {
            "provider": "openai",
            "model": "llama3-70b-8192",
            "base_url": "https://api.groq.com/openai/v1",
            "_env": "OPENAI_API_KEY=gsk_..."
        },
        "lmstudio_provider": {
            "provider": "lmstudio",
            "model": "mistral-7b",
            "base_url": "http://localhost:1234/v1",
            "cli_cmd": "lmstudio",
            "_env": "LMSTUDIO_ENABLED=true"
        },
        "deepseek_provider": {
            "provider": "deepseek",
            "model": "deepseek-chat",
            "cli_cmd": "deepseek",
            "_env": "DEEPSEEK_API_KEY=sk-...",
            "_comment": "deepseek-reasoner für komplexe Aufgaben"
        }
    }
}
